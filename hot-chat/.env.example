# Hot runtime location (the API exposed by `hot dev`).
HOT_API_URL=http://localhost:4681

# API key for the local Hot dev server.
#
# Hot Chat's Next.js server route holds this key (server-side only — the
# browser never sees it) and uses it to call /v1/streams/subscribe-with-event
# on the Hot runtime. Generate one in the Hot App: open http://localhost:4681
# → API Keys → New Key, then paste the value below. The key never leaves
# your machine for the local demo.
HOT_API_KEY=

# Optional default target: team-agent or personal-agent.
HOT_AGENT_TARGET=personal-agent

# Anthropic API key. When unset, Hot Chat falls back to a stub reply that
# tells the user the LLM is disabled — useful for offline tutorials and
# tests. Set this to a real key (from https://console.anthropic.com/) to
# get real, streamed answers grounded on agent memory.
ANTHROPIC_API_KEY=

# Optional model override. Defaults to claude-sonnet-4-5.
HOT_CHAT_MODEL=claude-sonnet-4-5
