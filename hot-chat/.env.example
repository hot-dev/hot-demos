# Hot runtime location (the API exposed by `hot dev`).
HOT_API_URL=http://localhost:4681

# API key for the local Hot dev server.
#
# Hot Chat's Next.js server route holds this key (server-side only — the
# browser never sees it) and uses it to call /v1/streams/subscribe-with-event
# on the Hot runtime. Generate one in the Hot App: open http://localhost:4681
# → API Keys → New Key, then paste the value below. The key never leaves
# your machine for the local demo.
HOT_API_KEY=

# Optional default target: team-agent or personal-agent.
HOT_AGENT_TARGET=personal-agent

# Chat model provider keys. Hot Chat can stream replies from Anthropic or
# OpenAI. When neither key is set, it falls back to a deterministic stub
# reply — useful for offline tutorials and tests.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional chat provider/model override. Provider can be auto, anthropic,
# or openai. Auto infers from HOT_CHAT_MODEL first, then uses whichever
# provider key is available. Defaults to claude-sonnet-4-5 for Anthropic
# and gpt-4o-mini for OpenAI.
HOT_CHAT_PROVIDER=auto
HOT_CHAT_MODEL=

# Optional local embedding switch-out. Leave unset for Hot's default
# embedding provider. Since Anthropic does not provide embeddings, set this
# to openai plus OPENAI_API_KEY to test Hot-level embed-fn / embed-batch-fn.
HOT_CHAT_EMBEDDING_PROVIDER=

