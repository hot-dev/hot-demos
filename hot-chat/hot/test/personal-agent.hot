::personal-agent::test ns

::demo ::personal-agent

// Event handlers in the demo take `event` and read `event.data`.
// Tests synthesize that envelope directly so they don't need the
// platform's event bus.
//
// Synthesis handlers (`daily-brief`, `task-inbox`) are exercised
// end-to-end in the live demo; tests here cover the dispatch shape,
// identity resolution, and writes that don't require an embedding
// provider.
//
// Free-chat handlers force the offline-stub path by clearing provider
// keys in ctx — keeps `hot test` hermetic and free.
::hot::ctx/set("anthropic.api.key", "")
::hot::ctx/set("openai.api.key", "")

mk-event fn (data: Map): Map { {data: data} }

base-data fn (user-id: Str, user-name: Str): Map {
    {
        user_id: user-id,
        user_name: user-name,
        message_id: `pa:${user-id}:test`,
        timestamp: 1700000000,
    }
}

// Free-chat / `/remember` persists the user turn into personal memory
// AND streams a reply through the configured LLM. With no
// chat provider API key available in the test environment, the handler
// falls back to a deterministic stub so this test stays hermetic. The
// memory write still happens — exercised end-to-end by `/recall`,
// `/brief`, and `/tasks` in the live demo.
test-remember-persists-and-replies
meta ["test"]
fn () {
    data {
        ...base-data(`u-${Uuid()}`, "Ada"),
        text: "I prefer launch updates that start with blockers.",
    }

    result ::demo/remember-message(mk-event(data))
    assert(result.ok)
    assert(contains(result.text, "ANTHROPIC_API_KEY or OPENAI_API_KEY"))
}

test-remember-handles-attachments
meta ["test"]
fn () {
    data {
        ...base-data(`u-${Uuid()}`, "Ada"),
        text: "Launch checklist attached",
        attachments: [{name: "checklist.md", type: "text/markdown", size: 256, text: "checklist body"}],
    }

    result ::demo/remember-message(mk-event(data))
    assert(result.ok)
}

test-whoami-defaults-session-to-person
meta ["test"]
fn () {
    data base-data("u-ada", "Ada")
    result ::demo/show-whoami(mk-event(data))
    assert(contains(result.text, "Session: person:u-ada"))
    assert(contains(result.text, "User: u-ada"))
}

test-guide-lists-commands
meta ["test"]
fn () {
    data base-data("u-ada", "Ada")
    result ::demo/show-guide(mk-event(data))
    assert(contains(result.text, "/remember"))
    assert(contains(result.text, "/recall"))
    assert(contains(result.text, "/brief"))
    assert(contains(result.text, "/tasks"))
    assert(contains(result.text, "/whoami"))
}
